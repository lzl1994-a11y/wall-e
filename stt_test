import sherpa_onnx
import sounddevice as sd
import sys

# 1. 填入你刚才下载的模型文件夹路径
model_dir = "F:\well-e-bot\sherpa-onnx"

print("⏳ 正在加载流式识别引擎...")
# 2. 初始化引擎 (注意：这个 14M 模型默认自带 Int8 量化版的文件)
recognizer = sherpa_onnx.OnlineRecognizer.from_transducer(
    tokens=f"{model_dir}/tokens.txt",
    encoder=f"{model_dir}/encoder-epoch-99-avg-1.int8.onnx",
    decoder=f"{model_dir}/decoder-epoch-99-avg-1.onnx",
    joiner=f"{model_dir}/joiner-epoch-99-avg-1.onnx",
    num_threads=1,         # 模拟单核运行，看看速度有多变态
    sample_rate=16000,
    feature_dim=80,
)

stream = recognizer.create_stream()

print("🎙️ 引擎就绪！请对着麦克风说话... (按 Ctrl+C 退出)")
print("-" * 50)

# 3. 麦克风回调函数：一拿到声音，立刻塞给引擎
def audio_callback(indata, frames, time, status):
    if status:
        print(status, file=sys.stderr)
    # 把麦克风采集的二维数组展平为一维
    samples = indata.reshape(-1)
    # 源源不断地把声音数据送入流中
    stream.accept_waveform(16000, samples)

# 4. 开启麦克风监听 (采样率 16000, 单声道)
try:
    with sd.InputStream(channels=1, dtype="float32", samplerate=16000, callback=audio_callback):
        while True:
            # 只要流里有数据没处理完，就疯狂解码
            while recognizer.is_ready(stream):
                recognizer.decode_stream(stream)
                
            # 实时获取刚才那 0.x 秒的最新识别结果
            result = recognizer.get_result(stream)
            if result:
                # \r 的作用是回车到行首，实现“文字不断往外冒”的流式动画效果
                print(f"\r[实时字幕]: {result}", end="", flush=True)

except KeyboardInterrupt:
    print("\n\n⏹️ 停止测试。")